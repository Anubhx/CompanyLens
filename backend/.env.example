
# Set to "groq" for free Llama 3 (recommended — 14,400 req/day free), or "gemini" for Google Gemini
ACTIVE_LLM=groq

# ─── Required — at least one Gemini key needed (for Legal Scout LLM analysis) ───
GEMINI_API_KEY=your_key_here          # aistudio.google.com — free, no card

# ─── Optional — dedicated per-agent keys bypass rate limits ───────────────────
GEMINI_API_KEY_LEGAL=your_key_here    # used for Legal Scout LLM call
GEMINI_API_KEY_FINANCE=your_key_here  # used if ACTIVE_LLM=gemini for Finance
GEMINI_API_KEY_DEV=your_key_here      # used if ACTIVE_LLM=gemini for Dev Scout
GEMINI_API_KEY_5=your_key_here        # extra rotation keys for Synthesiser
GEMINI_API_KEY_6=your_key_here        # extra rotation keys for Synthesiser

# ─── GROQ (free tier — recommended for Finance, Dev, Synthesiser) ─────────────
GROQ_API_KEY=your_key_here            # console.groq.com — free

# ─── External tools ───────────────────────────────────────────────────────────
TAVILY_API_KEY=your_tavily_key_here   # tavily.com — free 1000 searches/month
GITHUB_TOKEN=your_token_here          # github.com/settings/tokens — free
